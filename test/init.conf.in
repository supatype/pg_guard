<PG_EQ_15>
shared_preload_libraries='plpgsql_check'
</PG_EQ_15>
session_preload_libraries = 'pg_guard'
wal_level=logical

pg_guard.reserved_roles='supatype_storage_admin, anon, reserved_but_not_yet_created, authenticator*'
pg_guard.reserved_memberships='pg_read_server_files,pg_write_server_files,pg_execute_server_program,role_with_reserved_membership'
pg_guard.privileged_extensions='autoinc, citext, hstore, sslinfo, insert_username, dict_xsyn, postgres_fdw, pageinspect'
pg_guard.constrained_extensions='{"adminpack": { "cpu": 64}, "cube": { "mem": "17 GB"}, "lo": { "disk": "100 GB"}, "amcheck": { "cpu": 2, "mem": "100 MB", "disk": "100 MB"}}'
pg_guard.privileged_role='privileged_role'
pg_guard.privileged_role_allowed_configs='session_replication_role, pgrst.*, other.nested.*'
pg_guard.placeholders='response.headers, another.placeholder'
pg_guard.placeholders_disallowed_values='"content-type","x-special-header",special-value'
pg_guard.extensions_parameter_overrides='{"sslinfo":{"schema":"pg_catalog"}}'
pg_guard.drop_trigger_grants='{"privileged_role":["allow_drop_triggers.my_table"]}'
pg_guard.policy_grants='{"privileged_role":["allow_policies.my_table","allow_policies.nonexistent_table"]}'
pg_guard.extension_custom_scripts_path='@TMPDIR@/extension-custom-scripts'
